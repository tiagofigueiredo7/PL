START
PUSHN 1
PUSHS "ESCREVA UM VALOR INTEIRO: "
WRITES
WRITELN
READ
ATOI
STOREG 0
PUSHG 0
PUSHA PRINTMSG
CALL
POP 1
PUSHG 0
PUSHA DOBRA
CALL
POP 1
PUSHS "N ORIGINAL APOS CHAMADAS: "
WRITES
PUSHS " "
WRITES
PUSHG 0
WRITEI
WRITELN
STOP
PRINTMSG:
PUSHS "VALOR RECEBIDO: "
WRITES
PUSHS " "
WRITES
PUSHL -1
WRITEI
WRITELN
RETURN
DOBRA:
PUSHN 1
PUSHL -1
PUSHI 2
MUL
STOREL 0
PUSHS "DOBRO DE "
WRITES
PUSHS " "
WRITES
PUSHL -1
WRITEI
PUSHS " "
WRITES
PUSHS " = "
WRITES
PUSHS " "
WRITES
PUSHL 0
WRITEI
WRITELN
POP 1
RETURN